---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Separator } from "../components/ui/separator";
---

<BaseLayout title="Contact – Christopher Klint" description="Reach out to Christopher Klint for speaking engagements, tech consulting, or collaboration opportunities.">
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Contact</h1>
    <p class="mt-4 max-w-xl text-muted-foreground leading-relaxed">
      Whether you're looking for a speaker for your next event, want to discuss engineering leadership, or have a collaboration idea &mdash; I'd love to hear from you.
    </p>

    <Separator className="my-8" />

    <div class="space-y-8">
      <div>
        <h2 class="font-heading text-xl font-semibold">What I'm open to</h2>
        <ul class="mt-4 space-y-3 text-muted-foreground">
          <li><strong class="text-foreground">Speaking & podcasts:</strong> Conference talks, panels, and podcast guest appearances on engineering leadership, team building, feedback culture, and scaling tech organizations.</li>
          <li><strong class="text-foreground">Technology consulting:</strong> Strategic advice on cloud architecture (AWS, Azure, GCP), platform engineering, API design, and scaling engineering teams.</li>
          <li><strong class="text-foreground">Mentorship & advising:</strong> Happy to connect with engineering managers, aspiring leaders, and career changers navigating the tech industry.</li>
        </ul>
      </div>

      <div>
        <h2 class="font-heading text-xl font-semibold">Reach me directly</h2>
        <ul class="mt-4 space-y-3 text-muted-foreground">
          <li>
            <strong class="text-foreground">Email:</strong>{" "}
            <a href="mailto:christopher.klint@gmail.com" class="text-primary transition-colors hover:underline">
              christopher.klint@gmail.com
            </a>
          </li>
          <li>
            <strong class="text-foreground">LinkedIn:</strong>{" "}
            <a href="https://www.linkedin.com/in/christopherklint" target="_blank" rel="noopener noreferrer" class="text-primary transition-colors hover:underline">
              linkedin.com/in/christopherklint
            </a>
          </li>
          <li>
            <strong class="text-foreground">GitHub:</strong>{" "}
            <a href="https://github.com/christopherklint97" target="_blank" rel="noopener noreferrer" class="text-primary transition-colors hover:underline">
              github.com/christopherklint97
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="font-heading text-xl font-semibold">Schedule a call</h2>
        <p class="mt-2 text-muted-foreground">
          Want to chat about a speaking opportunity, collaboration, or just connect? Book a time that works for you.
        </p>
        <a
          href="https://cal.com/christopherklint/30-min"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex h-10 items-center justify-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
        >
          Book a 30-minute call
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

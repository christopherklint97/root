---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  GITHUB_USERNAME,
  fetchGitHubRepos,
  getDescription,
  languageColors,
  formatRepoName,
} from "../data/projects";

const repos = await fetchGitHubRepos();
---

<BaseLayout title="Projects | Christopher Klint" description="Open source projects and code by Christopher Klint.">
  <section class="mx-auto max-w-3xl px-6 py-12">
    <div class="animate-slide-up stagger-1">
      <h1 class="font-heading text-3xl tracking-tight sm:text-4xl">Projects</h1>
      <p class="mt-3 text-muted-foreground">
        Open source work and experiments, pulled from
        <a
          href={`https://github.com/${GITHUB_USERNAME}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground underline decoration-primary/40 underline-offset-4 transition-colors hover:decoration-primary"
        >GitHub</a> at build time.
      </p>
    </div>

    {repos.length === 0 ? (
      <p class="mt-10 text-muted-foreground animate-fade-in stagger-2">Couldn't load projects right now. Check back later.</p>
    ) : (
      <div class="mt-10 grid gap-3 sm:grid-cols-2">
        {repos.map((repo, i) => (
          <a
            href={repo.homepage || repo.html_url}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "group relative rounded-lg border border-border/60 p-5 transition-all duration-300",
              "hover:border-primary/30 hover:shadow-sm",
              "animate-slide-up",
              `stagger-${Math.min((i % 6) + 2, 8)}`,
            ]}
          >
            <div class="absolute inset-y-3 left-0 w-0.5 origin-top scale-y-0 rounded-full bg-primary transition-transform duration-300 group-hover:scale-y-100" />
            <h2 class="font-semibold text-foreground transition-colors group-hover:text-primary capitalize">
              {formatRepoName(repo.name)}
            </h2>
            <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground line-clamp-2">
              {getDescription(repo)}
            </p>
            <div class="mt-3 flex items-center gap-3 text-xs text-muted-foreground">
              {repo.language && (
                <span class="flex items-center gap-1.5">
                  <span
                    class="inline-block h-2 w-2 rounded-full"
                    style={`background-color: ${languageColors[repo.language] || "#6e7681"}`}
                  />
                  {repo.language}
                </span>
              )}
              {repo.stargazers_count > 0 && (
                <span class="flex items-center gap-1">
                  <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z" />
                  </svg>
                  {repo.stargazers_count}
                </span>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout title="Blog | Christopher Klint" description="Blog posts about software engineering and web development.">
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Blog</h1>
    <p class="mt-2 text-muted-foreground">Thoughts on software engineering, web development, and more.</p>

    <div class="mt-10 space-y-1">
      {posts.length === 0 && (
        <p class="text-muted-foreground">No posts yet. Check back soon!</p>
      )}
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group flex items-baseline gap-4 rounded-md px-2 py-3 transition-colors hover:bg-muted -mx-2"
        >
          <time
            datetime={post.data.date.toISOString()}
            class="shrink-0 text-sm tabular-nums text-muted-foreground"
          >
            {formatDate(post.data.date)}
          </time>
          <span class="font-medium text-foreground group-hover:text-primary transition-colors">
            {post.data.title}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
  fetchGitHubRepos,
  getDescription,
  languageColors,
  formatRepoName,
} from "../data/projects";

const thoughts = (await getCollection("thoughts"))
  .filter((t) => !t.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const repos = (await fetchGitHubRepos()).slice(0, 4);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout title="Christopher Klint | Engineering Leader & Builder" description="Christopher Klint is a Stockholm-based engineering leader who builds platforms, leads teams, and ships open source software.">
  <section class="mx-auto max-w-3xl px-6 py-20 sm:py-28">
    <!-- Hero -->
    <div class="animate-slide-up stagger-1">
      <h1 class="font-heading text-5xl tracking-tight sm:text-6xl lg:text-7xl">
        Christopher Klint
      </h1>
      <div class="mt-4 h-1 w-16 origin-left rounded-full bg-primary animate-grow stagger-3"></div>
    </div>
    <p class="mt-6 max-w-lg text-lg leading-relaxed text-muted-foreground animate-slide-up stagger-2">
      Engineering leader in Stockholm. I build platforms, lead teams, and care
      about shipping software that actually works. Currently at
      <a href="https://telnesstech.com" target="_blank" rel="noopener noreferrer" class="text-foreground underline decoration-primary/40 underline-offset-4 transition-colors hover:decoration-primary">Telness Tech</a>.
    </p>

    <!-- Projects -->
    {repos.length > 0 && (
      <div class="mt-20 animate-slide-up stagger-3">
        <div class="flex items-baseline justify-between">
          <h2 class="font-heading text-3xl">Projects</h2>
          <a href="/projects" class="text-sm text-muted-foreground transition-colors hover:text-primary">
            View all &rarr;
          </a>
        </div>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {repos.map((repo, i) => (
            <a
              href={repo.homepage || repo.html_url}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "group relative rounded-lg border border-border/60 p-5 transition-all duration-300",
                "hover:border-primary/30 hover:shadow-sm",
                "animate-slide-up",
                `stagger-${i + 4}`,
              ]}
            >
              <div class="absolute inset-y-3 left-0 w-0.5 origin-top scale-y-0 rounded-full bg-primary transition-transform duration-300 group-hover:scale-y-100" />
              <h3 class="font-semibold text-foreground transition-colors group-hover:text-primary capitalize">
                {formatRepoName(repo.name)}
              </h3>
              <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground line-clamp-2">
                {getDescription(repo)}
              </p>
              <div class="mt-3 flex items-center gap-3 text-xs text-muted-foreground">
                {repo.language && (
                  <span class="flex items-center gap-1.5">
                    <span
                      class="inline-block h-2 w-2 rounded-full"
                      style={`background-color: ${languageColors[repo.language] || "#6e7681"}`}
                    />
                    {repo.language}
                  </span>
                )}
                {repo.stargazers_count > 0 && (
                  <span>{repo.stargazers_count} stars</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Thoughts -->
    <div class="mt-20 animate-slide-up stagger-5">
      <div class="flex items-baseline justify-between">
        <h2 class="font-heading text-3xl">Thoughts</h2>
        {thoughts.length > 0 && (
          <a href="/thoughts" class="text-sm text-muted-foreground transition-colors hover:text-primary">
            View all &rarr;
          </a>
        )}
      </div>
      {thoughts.length === 0 ? (
        <p class="mt-6 text-muted-foreground">Coming soon.</p>
      ) : (
        <div class="mt-6 space-y-0 divide-y divide-border/60">
          {thoughts.map((thought) => (
            <a
              href={`/thoughts/${thought.id}`}
              class="group flex items-baseline gap-4 py-4 transition-colors"
            >
              <time
                datetime={thought.data.date.toISOString()}
                class="shrink-0 text-sm tabular-nums text-muted-foreground font-mono"
              >
                {formatDate(thought.data.date)}
              </time>
              <span class="font-medium text-foreground underline decoration-transparent underline-offset-4 transition-colors group-hover:decoration-primary/40">
                {thought.data.title}
              </span>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Speaking -->
    <div class="mt-20 animate-slide-up stagger-6">
      <h2 class="font-heading text-3xl">Speaking</h2>
      <div class="mt-6 space-y-0 divide-y divide-border/60">
        {[
          { event: "Women in Tech Sweden", topic: "Feedback culture and delivering it effectively", detail: "Regatta 2023" },
          { event: "EqualIT Podcast", topic: "Building inclusive teams through trust and vulnerability" },
          { event: "The Live Series", topic: "Effective collaboration in tech teams", detail: "Amicus" },
          { event: "Evolution Recruitment", topic: "Leadership and scaling engineering cultures" },
        ].map((item) => (
          <div class="py-4">
            <p class="font-medium text-foreground">
              {item.event}
              {item.detail && <span class="text-muted-foreground font-normal"> &middot; {item.detail}</span>}
            </p>
            <p class="mt-0.5 text-sm text-muted-foreground">{item.topic}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-sm text-muted-foreground">
        Open to events and podcasts.
        <a href="/contact" class="text-foreground underline decoration-primary/40 underline-offset-4 transition-colors hover:decoration-primary">Get in touch</a>.
      </p>
    </div>
  </section>
</BaseLayout>

---
import { ThemeToggle } from "./ThemeToggle";
import { MobileNav } from "./MobileNav";
---

<header class="sticky top-0 z-40 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="mx-auto flex h-14 max-w-3xl items-center justify-between px-6">
    <a href="/" class="font-heading text-lg font-bold text-foreground transition-colors hover:text-primary">
      Christopher Klint
    </a>

    <div class="flex items-center gap-1">
      <nav class="hidden md:flex md:items-center md:gap-1">
        <a
          href="/blog"
          class="rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
        >
          Blog
        </a>
        <a
          href="/contact"
          class="rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
        >
          Contact
        </a>
      </nav>
      <ThemeToggle client:load />
      <MobileNav client:load />
    </div>
  </div>
</header>
